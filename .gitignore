# Binaries
/repos
/repos.exe
/bin/
/dist/
*.test
*.out
*.exe
*.exe~
*.dll
*.so
*.dylib

# Coverage
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

